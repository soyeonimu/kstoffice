---
layout: null
permalink: /board/rss.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:dc="http://purl.org/dc/elements/1.1/">
<channel>
  <title>{{ site.title | xml_escape }} - 법률정보 게시판</title>
  <link>{{ '/board/' | absolute_url }}</link>
  <atom:link href="{{ '/board/rss.xml' | absolute_url }}" rel="self" type="application/rss+xml" />
  <description>수원 리더스 합동 법무사가 직접 작성한 개인회생·파산·형사·등기 법률정보</description>
  <language>ko</language>
  <generator>Jekyll</generator>
  {% assign posts = site.board | sort: "date" | reverse %}
  {% if posts.first %}<lastBuildDate>{{ posts.first.date | date_to_rfc822 }}</lastBuildDate>{% endif %}
  {% for post in posts limit:50 %}
  <item>
    <title>{{ post.title | xml_escape }}</title>
    <link>{{ post.url | absolute_url }}</link>
    <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
    <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
    <dc:creator>리더스 합동 법무사 사무소</dc:creator>
    {% if post.category %}<category>{{ post.category | xml_escape }}</category>{% endif %}
    <description>{{ post.description | default: post.excerpt | strip_html | strip_newlines | truncate: 200 | xml_escape }}</description>
  </item>
  {% endfor %}
</channel>
</rss>
