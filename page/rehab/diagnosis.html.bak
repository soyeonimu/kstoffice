    .why-title  { font-size: clamp(1.15rem, 5.5vw, 1.4rem) !important; margin-bottom: 20px !important; }

    /* ⑥ 리포트 카드 4→2열 */
    .report-cards { grid-template-columns: 1fr 1fr !important; gap: 10px !important; }
