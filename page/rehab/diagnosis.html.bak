    .sp-result strong { font-size: 12px !important; }
    .sp-cta-row .btn-gold {
      width: 100% !important; display: flex !important;
      justify-content: center !important; padding: 13px 20px !important;
    }

    /* ⑩ FAQ */
    .faq-btn  { font-size: 13px !important; padding: 14px 16px !important; line-height: 1.5 !important; }
    .faq-body { font-size: 13px !important; padding: 12px 16px 16px !important; }

    /* ⑪ 결과 */
    .lp-result { padding: 28px 16px 80px !important; }
    .result-inner { gap: 14px !important; }
    .result-top { padding: 20px 16px !important; border-radius: 18px !important; }
