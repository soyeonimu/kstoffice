  <section id="completeSection" class="hidden"></section>

</div>

<!-- ④ 모바일 플로팅 CTA (전화 + 진단) -->
<div class="float-cta" id="floatCta">
  <a href="tel:0312256885" class="fca-tel">
    📞 전화상담
  </a>
  <button class="fca-quiz" onclick="startQuiz()">
    📱 리포트 문자로 받기 →
  </button>
</div>

<script>
  function toggleAcc(btn) {
    const body = btn.nextElementSibling;
    const isOpen = body.classList.contains("open");
    // 모두 닫기
    document.querySelectorAll(".acc-body").forEach(b => b.classList.remove("open"));
    document.querySelectorAll(".acc-btn").forEach(b => b.classList.remove("open"));
    // 클릭한 것만 토글
    if (!isOpen) { body.classList.add("open"); btn.classList.add("open"); }
  }

  const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwKxN5Vl-7kNdeQcXdgeISiYxM2Ptcn-Yk6wCepJLQB8gfhiYpGMeJnOizNOso7Cdqx7g/exec";

  const questions = [
    /* 1 감정 진입 */
    { key:"mainConcern",  title:"현재 가장 걱정되는 문제는 무엇인가요?",
      sub:"해당되는 항목을 선택해 주세요.",
      options:["통장 압류","급여 압류","독촉 연락","카드대금 연체","대출 상환 부담","사업 실패","기타"] },
    /* 2 연체 여부 */
    { key:"arrears",      title:"현재 연체 중이신가요?",
      sub:"가장 오래된 연체 기간 기준으로 선택해 주세요.",
      options:["연체 없음","1개월 미만","1~3개월","3개월 이상","잘 모르겠다"] },
    /* 3 채무액 */
    { key:"debtAmount",   title:"총 채무액은 어느 정도인가요?",
      sub:"카드·대출·사채 등 모든 채무를 합산해 주세요.",
      options:["1천만원 이하","1천~3천만원","3천~5천만원","5천만원~1억원","1억원 이상"] },
    /* 4 직업 */
    { key:"job",          title:"현재 직업은 무엇인가요?",
      sub:"가장 가까운 항목을 선택해 주세요.",
      options:["직장인","자영업자","일용직","프리랜서","무직","기타"] },
    /* 5 소득 */
    { key:"monthlyIncome",title:"월 실수령액은 얼마인가요?",
      sub:"세금 공제 후 실제 받는 금액 기준입니다.",
      options:["150만원 이하","150~250만원","250~350만원","350~500만원","500만원 이상"] },
    /* 6 부양가족 */
    { key:"dependents",   title:"부양가족이 있으신가요?",
      sub:"생계를 함께하는 가족을 선택해 주세요. (중복 시 가장 중요한 항목)",
      options:["없음","배우자","자녀 1명","자녀 2명 이상","부모 부양","기타"] },
    /* 7 거주 */
    { key:"residence",    title:"현재 거주 형태는 무엇인가요?",
      options:["자가","전세","월세","부모님 집","기타"] },
    /* 8 차량 */
    { key:"hasCar",       title:"차량을 보유하고 계신가요?",
      sub:"본인 명의 기준입니다.",
      options:["없음","국산차 1대","수입차 1대","2대 이상","사업용 차량"] },
    /* 9 최근 대출 */
    { key:"recentLoan",   title:"최근 1년 이내 신규 대출이 있으신가요?",
      sub:"카드론·현금서비스 포함입니다.",
      options:["없음","1건","2건 이상","잘 모르겠다"] },
    /* 10 채무 원인 */
    { key:"debtReason",   title:"채무가 발생한 가장 큰 이유는 무엇인가요?",
      sub:"상담에서 중요하게 확인하는 항목입니다.",
      options:["생활비","사업 실패","주식","코인","도박","보증","병원비","기타"] },
    /* 11 보험 */
    { key:"insurance",    title:"해약환급금이 있는 보험을 보유 중이신가요?",
      sub:"종신·연금·저축성 보험이 해당됩니다.",
      options:["없음","있음","잘 모르겠다"] },
    /* 12 압류 */
    { key:"seizureStatus",title:"현재 압류 또는 추심이 진행 중인가요?",
      options:["없음","통장 압류","급여 압류","차량 압류","독촉 진행 중"] },
    /* 13 연령 (DB 분류용) */
    { key:"age",          title:"마지막으로 한 가지만 더 알려주세요.",
      sub:"연령대를 선택해 주세요.",
      options:["20대","30대","40대","50대","60대 이상"] }
  ];

  let cur = 0;
  const ans = {};
  const total = questions.length;

  const infoSections = document.getElementById("infoSections");
  const allInfoSections = document.querySelectorAll(".info-section, .why-section, .process-section, .faq-section, .social-proof-section, .scroll-hook, .report-claim, .authority-section, .pain-section, .stats-section");

  function toggleFaq(btn) {
    const body = btn.nextElementSibling;
    const isOpen = body.classList.contains("open");
    document.querySelectorAll(".faq-body").forEach(b => b.classList.remove("open"));
    document.querySelectorAll(".faq-btn").forEach(b => b.classList.remove("open"));
    if (!isOpen) { body.classList.add("open"); btn.classList.add("open"); }
  }

  function startQuiz() {
    document.getElementById("heroSection").classList.add("hidden");
    allInfoSections.forEach(s => s.classList.add("hidden"));
    document.getElementById("quizSection").classList.remove("hidden");
    window.scrollTo({ top: 0 });
    initDots();
    render();
  }

  function initDots() {
    document.getElementById("qDots").innerHTML =
      questions.map((_,i) => `<div class="q-dot" id="dot-${i}"></div>`).join("");
  }

  function updateDots() {
    questions.forEach((_,i) => {
      const d = document.getElementById(`dot-${i}`);
      d.className = "q-dot" + (i < cur ? " done" : i === cur ? " active" : "");
    });
  }

  function render() {
    const q = questions[cur];
    document.getElementById("stepLabel").textContent = `STEP ${cur+1} / ${total}`;
    updateDots();
    document.getElementById("questionBox").innerHTML = `
      <div class="q-title">${q.title}</div>
      ${q.sub ? `<div class="q-sub">${q.sub}</div>` : ""}
      <div class="q-options">
        ${q.options.map(o=>`
          <button class="q-opt" onclick="pick('${q.key}','${o}')">${o}</button>
        `).join("")}
      </div>`;
    // 1번 문제에서는 뒤로 버튼 숨김
    const backBtn = document.getElementById("backBtn");
    if (cur === 0) backBtn.classList.remove("visible");
    else backBtn.classList.add("visible");
  }

  function goBack() {
    if (cur <= 0) {
      document.getElementById("quizSection").classList.add("hidden");
      document.getElementById("heroSection").classList.remove("hidden");
      allInfoSections.forEach(s => s.classList.remove("hidden"));
      cur = 0;
      return;
    }
    cur--;
    delete ans[questions[cur].key];
    render();
  }

  function pick(key, val) {
    if (val === "기타") { showCustomInput(key); return; }
    ans[key] = val;
    cur++;
    if (cur < total) { render(); return; }
    document.getElementById("quizSection").classList.add("hidden");
    document.getElementById("loadingSection").classList.remove("hidden");
    window.scrollTo({ top: 0 });
    // 7초: 결과 화면으로
    setTimeout(() => {
      document.getElementById("loadingSection").classList.add("hidden");
      showReport();
    }, 7000);
  }

  function showCustomInput(key) {
    const q = questions[cur];
    // 기타 버튼 강조 + 입력창 노출 (기존 선택지 유지)
    document.getElementById("questionBox").innerHTML = `
      <div class="q-title">${q.title}</div>
      ${q.sub ? `<div class="q-sub">${q.sub}</div>` : ""}
      <div class="q-options">
        ${q.options.filter(o => o !== "기타").map(o =>
          `<button class="q-opt" onclick="pick('${key}','${o}')">${o}</button>`
        ).join("")}
        <button class="q-opt q-opt--active">기타</button>
      </div>
      <div class="q-custom-wrap">
        <input type="text" class="q-custom-input" id="customInput"
          placeholder="직접 입력해 주세요" maxlength="50"
          onkeydown="if(event.key==='Enter')submitCustom('${key}')">
        <button class="q-custom-btn" onclick="submitCustom('${key}')">확인 →</button>
      </div>`;
    setTimeout(() => document.getElementById("customInput")?.focus(), 60);
  }

  function submitCustom(key) {
    const val = (document.getElementById("customInput")?.value || "").trim();
    if (!val) {
      document.getElementById("customInput")?.classList.add("q-custom-input--error");
      return;
    }
    pick(key, `기타(${val})`);
  }

  function makeCode() {
    const n = new Date();
    return `KR-${String(n.getFullYear()).slice(2)}${String(n.getMonth()+1).padStart(2,"0")}${String(n.getDate()).padStart(2,"0")}-${Math.floor(1000+Math.random()*9000)}`;
  }

  function calcScore() {
    let score = 45;

    /* ── 연체 (위험 핵심 지표) ── */
    if (ans.arrears === "3개월 이상")  score += 18;
    if (ans.arrears === "1~3개월")     score += 10;
    if (ans.arrears === "1개월 미만")  score += 4;

    /* ── 채무 규모 ── */
    if (ans.debtAmount === "1억원 이상")      score += 20;
    if (ans.debtAmount === "5천만원~1억원")   score += 12;
    if (ans.debtAmount === "3천~5천만원")     score += 6;

    /* ── 직업·소득 ── */
    if (ans.job === "무직")    score += 10;
    if (ans.job === "일용직")  score += 5;
    if (ans.job === "자영업자") score += 4;

    if (ans.monthlyIncome === "150만원 이하")  score += 15;
    if (ans.monthlyIncome === "150~250만원")   score += 7;
    if (ans.monthlyIncome === "500만원 이상")  score -= 10;

    /* ── 부양가족 (변제금 낮아짐 → 유리) ── */
    if (ans.dependents === "자녀 2명 이상")  score -= 8;
    if (ans.dependents === "부모 부양")      score -= 5;
    if (ans.dependents === "자녀 1명")       score -= 3;
    if (ans.dependents === "배우자")         score -= 2;
    if (ans.dependents === "없음")           score += 3;

    /* ── 최근 대출 (사해행위 위험) ── */
    if (ans.recentLoan === "2건 이상")  score += 10;
    if (ans.recentLoan === "1건")       score += 5;

    /* ── 채무 원인 (추가 검토 필요 여부) ── */
    if (ans.debtReason === "도박")       score += 15;
    if (ans.debtReason === "코인")       score += 8;
    if (ans.debtReason === "주식")       score += 6;
    if (ans.debtReason === "사업 실패") score += 4;

    /* ── 보험 해약환급금 ── */
    if (ans.insurance === "있음")       score += 5;

    /* ── 압류 진행 중 ── */
    if (ans.seizureStatus === "통장 압류" ||
        ans.seizureStatus === "급여 압류" ||
        ans.seizureStatus === "차량 압류")  score += 10;
    if (ans.seizureStatus === "독촉 진행 중") score += 5;

    /* ── 차량 ── */
    if (ans.hasCar === "수입차 1대")  score += 8;
    if (ans.hasCar === "2대 이상")    score += 10;
    if (ans.hasCar === "국산차 1대")  score += 4;

    return Math.min(99, Math.max(30, score));
  }

  function calcStage(score) {
    if (score >= 85) return { icon:"🔴", text:"긴급 대응 단계", color:"#ef4444" };
    if (score >= 70) return { icon:"🟠", text:"집중 검토 단계", color:"#f97316" };
    if (score >= 50) return { icon:"🟡", text:"추가 확인 단계", color:"#f59e0b" };
    return { icon:"🟢", text:"진행 가능 단계", color:"#10b981" };
  }

  function stageDesc(score) {
    if (score >= 85) return "압류·추심·장기 연체 등의 사유로 신속한 검토가 필요한 상태입니다.\n상황에 따라 대응 시점이 중요할 수 있으므로 빠른 확인이 권장됩니다.";
    if (score >= 70) return "입력하신 정보 기준으로 최근 대출 여부, 재산 현황, 채무 발생 경위에 대한\n추가 확인이 필요한 것으로 분석됩니다.";
    if (score >= 50) return "개인회생 검토 가능성이 있으나 소득, 재산 또는 채무 내역에 대한\n추가 확인 후 보다 정확한 검토가 가능합니다.";
    return "현재 입력하신 정보 기준으로는 개인회생 검토가 가능한 범위로 보입니다.\n예상 변제금 산정 및 준비서류 확인을 위해 추가 자료 검토가 필요합니다.";
  }

  function buildInterp() {
    const ok   = [];
    const warn = [];

    /* ── 유리한 조건 ── */
    if (ans.dependents && ans.dependents !== "없음" && ans.dependents !== "기타")
      ok.push({
        text: `부양가족(${ans.dependents}) — 생계비 공제 반영으로 월 변제금 낮아질 수 있음`,
        detail: `${ans.dependents} 기준 생계비 공제액이 변제계획에 반영됩니다. 부양가족이 많을수록 법원이 인정하는 최저 생계비가 높아지고, 그만큼 월 변제금이 낮아집니다. 주민등록등본으로 부양 관계를 증명하면 됩니다.`
      });
    if (ans.hasCar === "없음")
      ok.push({
        text: "차량 미보유 — 재산 산정에서 차량 항목 제외",
        detail: "차량이 없으면 재산 목록 작성이 단순해지고 별도의 처분 계획이 필요 없습니다. 차량 보유자에 비해 준비서류가 줄어들고 절차 진행이 빠른 편입니다."
      });
    if (ans.recentLoan === "없음")
      ok.push({
        text: "최근 1년 신규 대출 없음 — 사해행위 검토 부담 없음",
        detail: "최근 대출이 없으면 채권자가 사해행위 취소소송을 제기할 근거가 약합니다. 회생 신청 전 재산 이전이나 편파 변제 여부도 검토 대상이 되므로, 대출 이력이 없는 것은 절차상 유리한 조건입니다."
      });
    if (ans.monthlyIncome === "250~350만원" || ans.monthlyIncome === "350~500만원")
      ok.push({
        text: "소득 수준 안정적 — 변제 능력 인정 가능성 높음",
        detail: `월 실수령액 ${ans.monthlyIncome} 기준으로 생계비 공제 후 일정 변제금 납부가 가능한 것으로 보입니다. 법원은 안정적 소득이 있는 경우 변제계획 인가를 더 긍정적으로 검토하는 경향이 있습니다.`
      });
    if (ans.residence === "전세" || ans.residence === "월세" || ans.residence === "부모님 집")
      ok.push({
        text: "자가 부동산 없음 — 부동산 재산 산정 부담 없음",
        detail: "자가 부동산이 없으면 부동산 처분 계획을 변제계획에 포함하지 않아도 됩니다. 전·월세 거주자는 임차보증금 반환채권을 재산으로 신고해야 하지만, 자가 대비 절차가 단순합니다."
      });
    if (ans.insurance === "없음")
      ok.push({
        text: "해약환급금 보험 없음 — 재산 산정 항목 단순",
        detail: "보험 해약환급금이 없으면 재산 목록 작성이 간소해집니다. 보험이 있는 경우 해약환급금을 재산으로 산정하고 경우에 따라 처분 여부를 결정해야 하지만, 이 항목은 해당하지 않습니다."
      });
    if (ans.job === "직장인")
      ok.push({
        text: "직장인 — 소득 증빙 서류 확보 용이",
        detail: "급여명세서, 근로소득원천징수영수증, 재직증명서 등 소득 증빙이 명확합니다. 법원에서 안정적 소득원으로 판단하여 변제계획 인가에 유리하게 작용할 수 있습니다."
      });

    /* ── 추가 확인 필요 항목 ── */
    if (ans.arrears === "3개월 이상")
      warn.push({
        text: "연체 3개월 이상 — 추심·압류 조치 진행 가능성",
        detail: "연체가 3개월을 넘으면 채권자가 지급명령 신청, 소송, 압류 조치를 취할 가능성이 높아집니다. 개인회생을 신청하면 자동 중지 명령으로 추가 강제집행을 막을 수 있으므로 신속한 검토가 권장됩니다."
      });
    if (ans.seizureStatus && ans.seizureStatus !== "없음")
      warn.push({
        text: `${ans.seizureStatus} 진행 중 — 즉시 회생 신청 검토 필요`,
        detail: `${ans.seizureStatus} 상태에서 개인회생을 신청하면 법원의 포괄적 금지명령 또는 중지명령을 통해 추가 집행을 막을 수 있습니다. 단, 이미 추심된 금액은 회복이 어려우므로 신청 시점이 매우 중요합니다.`
      });
    if (ans.debtReason === "도박")
      warn.push({
        text: "채무 원인(도박) — 소명 자료 준비 필수",
        detail: "도박은 낭비·사행행위에 해당하여 채무 발생 경위 소명이 중요합니다. 개인회생은 별도 면책 절차가 없어 파산과 달리 면책 불허가 사유가 직접 적용되지 않으나, 법원이 도덕적 해이를 부정적으로 볼 수 있습니다. 현재 상황 변화와 재발 방지 계획을 소명하는 것이 유리합니다."
      });
    if (ans.debtReason === "코인" || ans.debtReason === "주식")
      warn.push({
        text: `채무 원인(${ans.debtReason}) — 투기적 손실 소명 자료 준비`,
        detail: `${ans.debtReason} 투자 손실로 인한 채무는 거래 내역, 손실 경위, 투자 규모 등을 정리한 자료가 필요합니다. 채권자가 이의를 제기할 경우 소명 자료로 활용됩니다. 관련 거래 내역서를 사전에 확보해 두세요.`
      });
    if (ans.recentLoan === "2건 이상")
      warn.push({
        text: "최근 1년 신규 대출 2건 이상 — 사해행위 소명 필수",
        detail: "회생 신청 전 1년 이내 신규 대출이 여러 건 있으면 채권자가 사해행위 취소소송을 제기할 수 있습니다. 각 대출의 목적, 사용처, 현재 채무 포함 여부를 명확히 정리하고, 계약서 및 이체 내역을 준비해야 합니다."
      });
    if (ans.recentLoan === "1건")
      warn.push({
        text: "최근 1년 신규 대출 이력 — 경위 소명 자료 준비 권장",
        detail: "생활비, 기존 채무 상환 등 정당한 사유라면 크게 문제되지 않을 수 있습니다. 다만 대출 계약서, 용도에 맞는 사용 내역서 등을 미리 확보해 두면 이의 제기에 대비할 수 있습니다."
      });
    if (ans.insurance === "있음")
      warn.push({
        text: "해약환급금 보험 보유 — 재산 산정 및 처분 여부 검토 필요",
        detail: "종신·연금·저축성 보험의 해약환급금은 재산으로 산정됩니다. 환급금 규모에 따라 변제계획에 영향을 줄 수 있으며, 경우에 따라 해약 후 변제금으로 납입하도록 요구받을 수 있습니다. 보험사에 해약환급금 확인서를 요청하여 금액을 파악하세요."
      });
    if (ans.hasCar === "수입차 1대" || ans.hasCar === "2대 이상")
      warn.push({
        text: `차량 보유(${ans.hasCar}) — 재산 가액 산정 후 처분 계획 필요`,
        detail: "차량은 시가 기준으로 재산에 산정됩니다. 일정 가액 이상의 차량은 처분하여 변제금에 반영해야 할 수 있습니다. 차량 등록증 및 보험개발원 시세 조회 자료를 준비하고, 생계용 차량 여부도 함께 검토하세요."
      });
    if (ans.debtAmount === "1억원 이상")
      warn.push({
        text: "총 채무액 1억원 이상 — 채권자 목록 정밀 작성 필수",
        detail: "채무 규모가 크면 채권자 수도 많을 가능성이 높아 목록 작성이 복잡해집니다. 금융기관, 카드사, 개인 채권자 등 빠짐없이 파악하고 각 채권의 원금·이자·연체료를 정확히 정리해야 합니다. 누락된 채권자가 있으면 이의 제기 사유가 될 수 있습니다."
      });
    if (ans.job === "무직")
      warn.push({
        text: "현재 무직 — 소득 소명 또는 취업 계획 자료 준비",
        detail: "개인회생은 안정적인 수입이 있어야 변제계획 인가가 가능합니다. 현재 무직이라면 취업 예정 확인서, 아르바이트 수입, 임대소득, 부양가족의 소득 등 소득 발생 가능성을 입증할 수 있는 자료를 준비하는 것이 중요합니다."
      });

    /* ── 최소 보장 ── */
    if (ok.length === 0)
      ok.push({
        text: "기본 조건 확인 완료 — 변제 계획 수립 가능",
        detail: "입력하신 기본 정보를 바탕으로 개인회생 변제계획 수립이 가능한 것으로 보입니다. 상세 서류 확인 후 정확한 검토가 이루어집니다."
      });
    if (warn.length === 0)
      warn.push({
        text: "통장 거래내역 3~6개월 — 기본 제출 서류로 준비 필요",
        detail: "개인회생 신청 시 기본적으로 최근 3~6개월 통장 거래내역이 필요합니다. 은행 앱에서 PDF로 발급하거나 창구 방문 발급이 가능합니다. 거래 내역이 많은 경우 정리본을 별도로 작성하면 유리합니다."
      });

    return [
      ...ok.map(i   => ({ type:"ok",   icon:"✓", text:i.text, detail:i.detail })),
      ...warn.map(i  => ({ type:"warn", icon:"⚠", text:i.text, detail:i.detail }))
    ];
  }

  /* ─── 이번 진단 핵심 확인 항목 ─── */
  function buildKeyFactors() {
    const factors = [];
    if (ans.arrears === "3개월 이상")          factors.push({ t:"warn", text:"연체 3개월 이상" });
    else if (ans.arrears === "1~3개월")        factors.push({ t:"warn", text:"연체 1~3개월" });
    if (ans.seizureStatus && ans.seizureStatus !== "없음")
                                               factors.push({ t:"warn", text:`${ans.seizureStatus} 진행 중` });
    if (ans.debtAmount === "1억원 이상")       factors.push({ t:"warn", text:"총 채무 1억원 이상" });
    else if (ans.debtAmount === "5천만원~1억원") factors.push({ t:"warn", text:"총 채무 5천만원 이상" });
    if (ans.recentLoan === "2건 이상")         factors.push({ t:"warn", text:"신규 대출 2건 이상" });
    else if (ans.recentLoan === "1건")         factors.push({ t:"warn", text:"최근 신규 대출 있음" });
    if (ans.debtReason === "도박")             factors.push({ t:"warn", text:"채무 원인: 도박" });
    else if (["코인","주식"].includes(ans.debtReason))
                                               factors.push({ t:"warn", text:`채무 원인: ${ans.debtReason}` });
    if (ans.hasCar === "수입차 1대" || ans.hasCar === "2대 이상")
                                               factors.push({ t:"warn", text:`차량 보유(${ans.hasCar})` });
    if (ans.insurance === "있음")              factors.push({ t:"warn", text:"보험 해약환급금 보유" });
    if (ans.job === "무직")                    factors.push({ t:"warn", text:"무직" });
    // 긍정 요소 (최대 1개)
    if (ans.dependents && ans.dependents !== "없음" && ans.dependents !== "기타")
                                               factors.push({ t:"ok",   text:`부양가족 ${ans.dependents}` });
    return factors.slice(0, 5);
  }

  /* ─── 숫자 카운트업 ─── */
  function countUp(el, end, suffix, duration = 900) {
    if (!el) return;
    const startTime = performance.now();
    (function update(now) {
      const p = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.innerHTML = `${Math.round(eased * end)}<span style="font-size:16px;">${suffix}</span>`;
      if (p < 1) requestAnimationFrame(update);
    })(startTime);
  }

  /* ─── 예상 월 변제금 범위 계산 ─── */
  function calcRepayment() {
    const incomeMap = {
      "150만원 이하":120, "150~250만원":200,
      "250~350만원":300, "350~500만원":420, "500만원 이상":550
    };
    const livingMap = {
      "없음":95, "배우자":145, "자녀 1명":165,
      "자녀 2명 이상":190, "부모 부양":175, "기타":120
    };
    const income = incomeMap[ans.monthlyIncome] ?? 200;
    const living = livingMap[ans.dependents] ?? 100;
    const base   = Math.max(20, income - living);
    const lo     = Math.round(base * 0.82 / 10) * 10;
    const hi     = Math.round(base * 1.18 / 10) * 10;
    return `${lo}~${hi}만원`;
  }

  /* ─── 예상 준비서류 건수 ─── */
  function calcDocCount() {
    let n = 10;
    if (ans.job === "자영업자")                                n += 3;
    if (ans.job === "일용직" || ans.job === "프리랜서")        n += 2;
    if (ans.recentLoan && ans.recentLoan !== "없음")           n += 2;
    if (ans.hasCar && ans.hasCar !== "없음")                   n += 2;
    if (ans.insurance === "있음")                              n += 2;
    if (ans.seizureStatus && ans.seizureStatus !== "없음")     n += 2;
    if (ans.residence === "자가")                              n += 1;
    return `${n}건`;
  }

  /* ─── 경고 항목 (빨간 강조 블록) ─── */
  function buildWarnAlerts() {
    const warns = [];
    if (ans.seizureStatus && ans.seizureStatus !== "없음")
      warns.push(`현재 ${ans.seizureStatus} 상태로 신속한 대응이 필요합니다.`);
    if (ans.debtReason === "도박")
      warns.push("채무 원인(도박) — 면책 불허가 사유 검토가 반드시 필요합니다.");
    else if (ans.debtReason === "코인" || ans.debtReason === "주식")
      warns.push(`채무 원인(${ans.debtReason}) 관련 소명 자료 준비가 필요합니다.`);
    if (ans.recentLoan === "2건 이상")
      warns.push("최근 1년 내 신규 대출 2건 이상 확인 — 경위 소명이 필요합니다.");
    else if (ans.recentLoan === "1건")
      warns.push("최근 1년 내 신규 대출 이력 확인 — 소명 자료 준비 권장.");
    return warns;
  }

  /* ─── 동적 단계 설명 (사용자 답변 반영) ─── */
  function buildDynamicDesc() {
    const lines = [];

    if (ans.arrears === "3개월 이상")
      lines.push("연체 기간이 3개월 이상으로 확인되었습니다.");
    else if (ans.arrears === "1~3개월")
      lines.push("1~3개월 연체 이력이 확인되었습니다.");

    if (ans.debtAmount === "1억원 이상")
      lines.push("총 채무액이 1억원 이상으로 채권자 목록 정밀 검토가 필요합니다.");
    else if (ans.debtAmount === "5천만원~1억원")
      lines.push("총 채무액 규모상 개인회생 검토 가능 범위로 보입니다.");

    lines.push("추가 자료 확인 후 보다 정확한 검토가 가능합니다.");

    return lines.slice(0, 3).join("\n");
  }

  /* ─── 상태 분석 항목 토글 ─── */
  function toggleInterp(header) {
    const detail = header.nextElementSibling;
    const isOpen = detail.classList.contains("open");
    // 다른 항목 닫기
    document.querySelectorAll(".interp-detail").forEach(d => d.classList.remove("open"));
    document.querySelectorAll(".interp-header").forEach(h => h.classList.remove("open"));
    if (!isOpen) {
      detail.classList.add("open");
      header.classList.add("open");
    }
  }

  /* ─── 입력 정보 아코디언 토글 ─── */
  function toggleSummary(btn) {
    const body = document.getElementById("summaryList");
    const isOpen = body.style.display !== "none";
    body.style.display = isOpen ? "none" : "block";
    btn.classList.toggle("open", !isOpen);
  }

  /* ── 공개 결과 헬퍼 ── */
  function calcPossibility() {
    const score = calcScore();
    if (score >= 70) return { text: "🟢 진행 가능성 높음",    cls: "v-high" };
    if (score >= 50) return { text: "🟡 추가 검토 필요",       cls: "v-mid" };
    return             { text: "🔴 신청 전 보완 필요",         cls: "v-urgent" };
  }
  function calcUrgency() {
    const s = ans.seizureStatus || "";
    if (s === "통장 압류" || s === "급여 압류" || s === "차량 압류") return { text: "긴급", cls: "v-urgent" };
    if (s === "독촉 진행 중" || ans.arrears === "3개월 이상") return { text: "높음", cls: "v-mid" };
    if (ans.arrears === "연체 없음") return { text: "낮음", cls: "v-high" };
    return { 