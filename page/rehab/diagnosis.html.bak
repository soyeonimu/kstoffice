      width: 100% !important;
      border-radius: 0 !important;
      min-width: unset !important;
      flex: none !important;
    }
    .process-step:first-child { border-radius: 14px 14px 0 0 !important; }
    .process-step:last-child  { border-radius: 0 0 14px 14px !important; }
    .ps-title { font-size: 13px !important; }
    .ps-desc  { font-size: 11px !important; }

    /* ⑨ 사회적 증거 2열 */
    .sp-cards   { grid-template-columns: 1fr 1fr !important; gap: 10px !important; }
    .sp-card    { padding: 12px !important; gap: 8px !important; }
    .sp-stage   { font-size: 10px !important; padding: 3px 8px !important; white-space: nowrap; }
    .sp-profile { font-size: 11px !important; }
    .sp-detail  { font-size: 10px !important; }
