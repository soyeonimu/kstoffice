    .result-badge  { font-size: 10px !important; padding: 3px 10px !important; }
    .pub-grid { grid-template-columns: repeat(3, 1fr) !important; gap: 8px !important; }
    .pub-value { font-size: 14px !important; }
    .pub-label { font-size: 9px !important; }
