  <!-- ④ 결과 -->
  <section id="reportSection" class="lp-result hidden">
    <div class="result-inner">

      <!-- ① 긴급 대응 단계 + 핵심 분석 결과 + CTA (다크 통합) -->
      <div class="diag-block">

        <!-- 스테이지 신호 + 수치 -->
        <div class="diag-top">
          <div class="result-header-row">
            <span class="result-badge">개인회생 사전진단 리포트</span>
            <span class="result-ts" id="reportTs"></span>
          </div>
          <div class="result-stage-row">
            <div class="stage-signal" id="stageSignal">
              <div class="ss-ring1"></div>
              <div class="ss-ring2"></div>
              <div class="ss-core"></div>
            </div>
            <h2 id="resultStageText">추가 확인 단계</h2>
          </div>
          <div class="pub-grid" style="margin-top:16px;">
            <div class="pub-item">
              <div class="pub-label">진행 가능성</div>
              <div class="pub-value" id="pubPossibility">—</div>
            </div>
            <div class="pub-item">
              <div class="pub-label">압류 위험도</div>
              <div class="pub-value" id="pubUrgency">—</div>
            </div>
            <div class="pub-item">
              <div class="pub-label">예상 변제기간</div>
              <div class="pub-value" id="pubPeriod">—</div>
            </div>
          </div>
          <div class="result-code" id="reportCode"></div>
        </div>

        <!-- 핵심 분석 결과 (잠금) -->
        <div class="diag-dash-head">
          <span class="dash-title">핵심 분석 결과</span>
          <span class="dash-badge">1차 자동 분석</span>
        </div>
        <div class="dash-grid">
          <div class="dash-cell" id="dashCell1">
            <div class="dash-key">예상 월 변제금</div>
            <div class="dash-val dash-locked" id="lockedRepayment"></div>
          </div>
          <div class="dash-cell" id="dashCell2">
            <div class="dash-key">예상 탕감 가능 금액</div>
            <div class="dash-val dash-locked" id="lockedReduction"></div>
          </div>
          <div class="dash-cell" id="dashCell3">
            <div class="dash-key">신청 검토 단계</div>
            <div class="dash-val dash-locked" id="lockedSeizure"></div>
          </div>
          <div class="dash-cell" id="dashCell4">
            <div class="dash-key">예상 변제기간</div>
            <div class="dash-val dash-locked" id="lockedOpinion"></div>
          </div>
        </div>

        <!-- 리포트 미리보기 + CTA -->
        <div class="report-preview">
          <div class="rp-label">📄 문자로 안내되는 내용</div>
          <ul class="rp-list">
            <li>예상 월 변제금</li>
            <li>예상 탕감 범위</li>
            <li>개인회생 진행 가능성</li>
            <li>필요 준비서류</li>
          </ul>
        </div>
        <div class="dash-gate" id="repayGate">
          <button class="dash-gate-btn" onclick="openRepayForm()">📱 리포트 문자로 받기 →</button>
        </div>
        <div class="repay-mini-form hidden" id="repayMiniForm">
          <div class="rmf-title">번호를 남겨주시면<br><em>진단 리포트를 문자로 보내드립니다</em></div>
          <form onsubmit="submitRepayForm(event)">
            <input id="rmfPhone" type="tel" placeholder="010 - 0000 - 0000" maxlength="15" required />
            <label class="rmf-check">
              <input id="rmfAgree" type="checkbox" required />
              <span>개인정보 수집·이용 동의</span>
            </label>
            <button type="submit" class="btn-gold">문자로 결과 받기 →</button>
          </form>
          <p class="rmf-note">📱 입력하신 번호로 리포트를 문자 발송해드립니다.<br>이후 필요 시에만 담당 법무사가 연락드립니다.</p>
        </div>
        <div class="dash-footer" id="unlockGate" style="display:none;">
          <p class="dash-footer-note">담당 법무사가 검토 후 문자로 정확한 결과를 안내드립니다.</p>
          <a href="tel:0312256885" class="dash-tel-btn">📞 무료 전화상담 →</a>
          <p class="dash-reassure">✓ 전화 부담 없음 &nbsp;·&nbsp; ✓ 수임 의무 없음 &nbsp;·&nbsp; ✓ 비밀 보장</p>
        </div>

